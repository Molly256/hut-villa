import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';

const API_URL = '/api';

export default function BankInfo() {
  const [method, setMethod] = useState('MTN Mobile Money');
  const [number, setNumber] = useState('');
  const [name, setName] = useState('');
  const [loading, setLoading] = useState(false);
  const [user, setUser] = useState(null);
  const navigate = useNavigate();

  useEffect(() => {
    const savedUser = localStorage.getItem('hutvilla_user');
    if (!savedUser) {
      navigate('/login');
      return;
    }
    const parsedUser = JSON.parse(savedUser);
    setUser(parsedUser);
    setMethod(parsedUser.bankMethod || 'MTN Mobile Money');
    setNumber(parsedUser.bankNumber || '');
    setName(parsedUser.bankName || '');
  }, [navigate]);

  const handleSave = async () => {
    if (!number ||!name) {
      alert("Fill all fields");
      return;
    }

    setLoading(true);
    try {
      const res = await fetch(`${API_URL}/update-bank`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phoneNumber: user.phone,
          bankMethod: method,
          bankNumber: number,
          bankName: name
        })
      });

      const data = await res.json();
      if (!res.ok) {
        alert(data.error || 'Failed to save bank info');
        setLoading(false);
        return;
      }

      const updatedUser = {...user, bankMethod: method, bankNumber: number, bankName: name };
      setUser(updatedUser);
      localStorage.setItem('hutvilla_user', JSON.stringify(updatedUser));

      alert("Bank info saved");
      navigate("/settings");
    } catch (err) {
      alert("Network error. Try again.");
    }
    setLoading(false);
  };

  if (!user) return null;

  return (
    <div style={{ background: '#1a1a1a', minHeight: '100vh', color: 'white', padding: '20px' }}>
      <button
        onClick={() => navigate(-1)}
        style={{ background: 'none', border: 'none', color: 'white', fontSize: '20px', marginBottom: '20px', cursor: 'pointer' }}
      >
        ← Back
      </button>

      <h3 style={{ textAlign: 'center', marginBottom: '30px' }}>Bank Information</h3>

      <label style={{ fontSize: '14px', color: '#999' }}>Select method</label>
      <select
        value={method}
        onChange={e => setMethod(e.target.value)}
        style={styles.input}
      >
        <option>MTN Mobile Money</option>
        <option>Airtel Mobile Money</option>
      </select>

      <input
        type="text"
        placeholder="Input number..."
        value={number}
        onChange={e => setNumber(e.target.value)}
        style={styles.input}
      />

      <input
        type="text"
        placeholder="Input names..."
        value={name}
        onChange={e => setName(e.target.value)}
        style={styles.input}
      />

      <p style={{ fontSize: '12px', color: '#aaa', marginTop: '15px' }}>
        Save the phone number you want the manager to deposit your income on and the names those numbers show.
      </p>

      <button
        onClick={handleSave}
        disabled={loading}
        style={styles.button}
      >
        {loading? 'Saving...' : 'Save'}
      </button>
    </div>
  );
}

const styles = {
  input: {
    width: '100%',
    padding: '12px',
    margin: '10px 0',
    borderRadius: '8px',
    border: '1px solid #333',
    background: '#2a2a2a',
    color: 'white',
    fontSize: '14px',
    outline: 'none',
    boxSizing: 'border-box'
  },
  button: {
    width: '100%',
    padding: '15px',
    background: '#007bff',
    color: 'white',
    border: 'none',
    borderRadius: '8px',
    marginTop: '20px',
    fontSize: '16px',
    fontWeight: '600',
    cursor: 'pointer'
  }
};